# INFORM Risk Management System Configuration
# Copy this file to .env and update with your settings

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Local development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/inform_db?sslmode=disable

# Production (update with your database credentials)
# DATABASE_URL=postgres://user:password@your-db-host:5432/inform_db?sslmode=require

# =============================================================================
# SECURITY
# =============================================================================
# JWT Secret - MUST change this in production!
JWT_SECRET=your-secure-secret-key-change-in-production

# =============================================================================
# SERVER
# =============================================================================
SERVER_PORT=8080

# CORS - Allowed origins (comma-separated)
CORS_ORIGINS=https://inform.co.tz,https://www.inform.co.tz

# =============================================================================
# PRODUCTION DOMAIN
# =============================================================================
# API will be accessible at: https://api.inform.co.tz
# Frontend domain: https://inform.co.tz

# INFORM Tanzania Platform - Environment Variables

# Supabase Configuration (optional - for database)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Go Backend API URL (optional - uses /api/v1 proxy in development)
# Set this for production deployments
# VITE_API_URL=https://your-backend-url.com/api/v1

# Leave empty or comment out to use Vite proxy (development)
# Or set to full URL for production

# INFORM Tanzania Platform - Environment Variables
# Copy this file to .env and update with your settings

# =============================================================================
# PRODUCTION SETTINGS (inform.co.tz)
# =============================================================================

# Go Backend API URL
VITE_API_URL=https://api.inform.co.tz/api/v1

# Supabase Configuration (for real-time updates and data persistence)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# DEVELOPMENT SETTINGS (localhost)
# =============================================================================
# Uncomment these for local development:
# VITE_API_URL=http://localhost:8080/api/v1
# Or leave VITE_API_URL empty to use Vite proxy

{
  "name": "model",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:warning": "vite --open warning-app.html",
    "build": "vite build",
    "build:warning": "vite build --mode warning",
    "build:warning-only": "rm -rf dist && vite build && mkdir -p dist/warning && cp dist/warning.js dist/warning/ && cp warning-app.html dist/warning/index.html",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:warning": "vite preview --open",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "homepage": "https://masuby.github.io/model",
  "dependencies": {
    "@supabase/supabase-js": "^2.95.2",
    "d3": "^7.9.0",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "echarts-gl": "^2.0.9",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.4",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "mapbox-gl": "^3.15.0",
    "npm": "^11.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-draw": "^0.21.0",
    "react-router-dom": "^7.10.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@turf/turf": "^7.3.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.23",
    "gh-pages": "^6.3.0",
    "globals": "^16.4.0",
    "shapefile": "^0.6.6",
    "shpjs": "^6.2.0",
    "vite": "^7.1.10"
  }
}
